# ─── Environment ──────────────────────────────────────────────
ENV=development

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Settings > API > service_role

# ─── AI Models ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ─── GitHub App ───────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=    # PEM key, base64 encode for env var
GITHUB_WEBHOOK_SECRET=     # Random secret for HMAC verification

# ─── Notion ───────────────────────────────────────────────────
NOTION_API_KEY=secret_...  # Optional

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# For Upstash (prod): rediss://default:PASSWORD@HOST:PORT

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://cortex-omega-one.vercel.app"]
